---
const navLinks = [
  { href: '/apps', label: 'Apps' },
  { href: 'https://medium.com/@wchin24', label: 'Writing', external: true },
];

const socialLinks = [
  {
    href:  'https://github.com/wchin24',
    label: 'GitHub',
    icon:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
    </svg>`,
  },
  {
    href:  'https://twitter.com/wchin24',
    label: 'Twitter / X',
    icon:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>`,
  },
  {
    href:  'https://linkedin.com/in/williamchin24',
    label: 'LinkedIn',
    icon:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>`,
  },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || currentPath.startsWith(href + '/');
---

<header class="sticky top-0 z-40 w-full border-b border-cream-300 bg-cream-100/80 backdrop-blur-md">
  <nav class="page-container flex items-center justify-between h-16">

    <!-- Wordmark -->
    <a href="/" class="group flex items-center gap-2" aria-label="William Chin — home">
      <div class="w-8 h-8 rounded-lg bg-accent flex items-center justify-center
                  shadow-sm group-hover:shadow-[0_0_12px_rgba(91,79,207,0.4)]
                  transition-shadow duration-300">
        <span class="text-white text-sm font-bold font-serif leading-none">W</span>
      </div>
      <span class="font-semibold text-ink tracking-tight hidden sm:block">
        William Chin
      </span>
    </a>

    <!-- Right side: nav links + social icons -->
    <div class="flex items-center gap-1">

      <!-- Page links -->
      <ul class="flex items-center gap-1 mr-3" role="list">
        {navLinks.map(({ href, label, external }) => (
          <li>
            <a
              href={href}
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              class:list={[
                'relative px-3 py-1.5 rounded-lg text-sm font-medium transition-colors duration-200',
                !external && isActive(href)
                  ? 'text-accent bg-accent/8'
                  : 'text-ink-muted hover:text-ink hover:bg-cream-300',
              ]}
              aria-current={!external && isActive(href) ? 'page' : undefined}
            >
              {label}
              {!external && isActive(href) && (
                <span class="absolute bottom-0.5 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-accent" />
              )}
            </a>
          </li>
        ))}
      </ul>

      <!-- Divider -->
      <div class="w-px h-5 bg-cream-300 mr-3" aria-hidden="true" />

      <!-- Social icons -->
      <ul class="flex items-center gap-0.5" role="list">
        {socialLinks.map(({ href, label, icon }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="flex items-center justify-center w-8 h-8 rounded-lg
                     text-ink-faint hover:text-accent hover:bg-accent/8
                     transition-colors duration-200"
              set:html={icon}
            />
          </li>
        ))}
      </ul>

    </div>
  </nav>
</header>
