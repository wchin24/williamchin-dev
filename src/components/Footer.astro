---
const year = new Date().getFullYear();
---

<footer class="border-t border-cream-300 mt-24">
  <div class="page-container py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-ink-faint">
      © {year} William Chin.
    </p>

    <div class="flex items-center gap-5">
      <!-- Ko-fi -->
      <a
        href="https://ko-fi.com/williamchin"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Support on Ko-fi"
        class="flex items-center gap-1.5 text-sm text-ink-faint hover:text-[#FF5E5B] transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 2.694.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/>
        </svg>
        Ko-fi
      </a>

      <span class="text-cream-400 select-none">·</span>

      <!-- Buy Me a Coffee -->
      <a
        href="https://buymeacoffee.com/williamchin"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Buy Me a Coffee"
        class="flex items-center gap-1.5 text-sm text-ink-faint hover:text-amber-warm transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.829-.05.992-.440.164-.39-.027-.82-.399-.962a13.46 13.46 0 00-.612-.176 27.82 27.82 0 00-1.454-.285 27.47 27.47 0 00-3.728-.193 26.074 26.074 0 00-3.65.32 16.35 16.35 0 00-1.67.38c-.371.108-.745.244-1.061.483-.33.247-.558.6-.558 1.021 0 .547.26 1.031.652 1.397.343.32.762.527 1.198.68 1.01.356 2.084.518 3.148.62 1.286.124 2.578.115 3.87.018.568-.044 1.135-.107 1.699-.196.232-.038.467-.077.697-.126.234-.05.374-.29.323-.521l-.002-.01zM6.25 9.928c0-.166.135-.3.3-.3h11.2c.166 0 .3.134.3.3v.228c0 .165-.134.3-.3.3H6.55a.3.3 0 01-.3-.3v-.228zm.786 2.105c-.065-.322.194-.627.522-.627h9.887c.328 0 .587.305.522.627l-.72 3.598c-.304 1.52-1.645 2.618-3.194 2.618H10.95c-1.548 0-2.89-1.098-3.194-2.618l-.72-3.598z"/>
